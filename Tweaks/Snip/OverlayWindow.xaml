<Window x:Class="Stamps.Tweaks.Snip.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="Cross"
        Background="Black"
        WindowStartupLocation="Manual"
        KeyDown="OnKeyDown"
        MouseDown="OnMouseDown"
        MouseMove="OnMouseMove"
        MouseUp="OnMouseUp">
    <Canvas x:Name="RootCanvas" Background="Transparent">
        <!-- Original screenshot, stretched to fill the window in DIPs -->
        <Image x:Name="ScreenImage" Canvas.Left="0" Canvas.Top="0" Stretch="Fill"/>
        <!-- Dark tint overlay -->
        <Rectangle x:Name="TintLayer" Canvas.Left="0" Canvas.Top="0" Fill="#64000000"/>
        <!-- Selection area: reveals the original (un-tinted) screenshot -->
        <Rectangle x:Name="SelectionReveal"
                   Canvas.Left="0" Canvas.Top="0"
                   Width="0" Height="0"
                   Visibility="Hidden">
            <Rectangle.Fill>
                <!-- ViewboxUnits=Absolute so Viewbox is in physical image pixel coordinates -->
                <ImageBrush x:Name="RevealBrush"
                            ViewboxUnits="Absolute"
                            Stretch="Fill"
                            TileMode="None"/>
            </Rectangle.Fill>
        </Rectangle>
        <!-- 1px white selection border -->
        <Rectangle x:Name="SelectionBorder"
                   Canvas.Left="0" Canvas.Top="0"
                   Width="0" Height="0"
                   Stroke="White" StrokeThickness="1"
                   Fill="Transparent"
                   Visibility="Hidden"/>
    </Canvas>
</Window>
