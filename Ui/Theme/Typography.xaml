<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <FontFamily x:Key="Stamps.FontFamily">Segoe UI Variable, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="Stamps.FontFamily.Mono">Cascadia Code, Consolas, monospace</FontFamily>

    <system:Double x:Key="Stamps.FontSize.Caption"  xmlns:system="clr-namespace:System;assembly=mscorlib">11</system:Double>
    <system:Double x:Key="Stamps.FontSize.Body"     xmlns:system="clr-namespace:System;assembly=mscorlib">13</system:Double>
    <system:Double x:Key="Stamps.FontSize.Subtitle" xmlns:system="clr-namespace:System;assembly=mscorlib">16</system:Double>
    <system:Double x:Key="Stamps.FontSize.Title"    xmlns:system="clr-namespace:System;assembly=mscorlib">20</system:Double>
    <system:Double x:Key="Stamps.FontSize.Header"   xmlns:system="clr-namespace:System;assembly=mscorlib">28</system:Double>

</ResourceDictionary>
