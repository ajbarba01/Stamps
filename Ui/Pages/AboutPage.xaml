<UserControl x:Class="Stamps.Ui.Pages.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="28,20,28,0">
        <TextBlock x:Name="AppNameText"
                   Text="Stamps"
                   FontFamily="{DynamicResource Stamps.FontFamily}"
                   FontSize="{DynamicResource Stamps.FontSize.Header}"
                   FontWeight="Bold"
                   Foreground="{DynamicResource Stamps.Text.Primary}"
                   Margin="0,0,0,4"/>
        <TextBlock x:Name="VersionText"
                   FontFamily="{DynamicResource Stamps.FontFamily}"
                   FontSize="{DynamicResource Stamps.FontSize.Body}"
                   Foreground="{DynamicResource Stamps.Text.Secondary}"
                   Margin="0,0,0,16"/>
        <TextBlock Text="A tray-resident control panel for a growing library of small Windows tweaks."
                   FontFamily="{DynamicResource Stamps.FontFamily}"
                   FontSize="{DynamicResource Stamps.FontSize.Body}"
                   Foreground="{DynamicResource Stamps.Text.Secondary}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,24"/>
        <Button x:Name="OpenLogsButton"
                Content="Open log folder"
                Click="OnOpenLogsClick"
                Padding="16,8"/>
    </StackPanel>
</UserControl>
