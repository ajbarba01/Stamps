<UserControl
    x:Class="Stamps.Ui.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="28,20,28,0">
        <TextBlock
            x:Name="AppNameText"
            Margin="0,0,0,4"
            FontFamily="{DynamicResource Stamps.FontFamily}"
            FontSize="{DynamicResource Stamps.FontSize.Header}"
            FontWeight="Bold"
            Foreground="{DynamicResource Stamps.Text.Primary}"
            Text="Stamps" />
        <TextBlock
            x:Name="VersionText"
            Margin="0,0,0,16"
            FontFamily="{DynamicResource Stamps.FontFamily}"
            FontSize="{DynamicResource Stamps.FontSize.Body}"
            Foreground="{DynamicResource Stamps.Text.Secondary}" />
        <TextBlock
            Margin="0,0,0,24"
            FontFamily="{DynamicResource Stamps.FontFamily}"
            FontSize="{DynamicResource Stamps.FontSize.Body}"
            Foreground="{DynamicResource Stamps.Text.Secondary}"
            Text="A tray-resident control panel for a growing library of small Windows tweaks."
            TextWrapping="Wrap" />
    </StackPanel>
</UserControl>
