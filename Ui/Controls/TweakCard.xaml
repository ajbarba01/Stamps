<UserControl x:Class="Stamps.Ui.Controls.TweakCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Margin="0,0,0,8" Cursor="Hand">
    <Border x:Name="CardBorder"
            Background="{DynamicResource Stamps.Background.Card}"
            BorderBrush="{DynamicResource Stamps.Border.Default}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,12">
        <Grid Height="56">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Icon -->
            <Image x:Name="IconImage" Grid.Column="0"
                   Width="40" Height="40"
                   HorizontalAlignment="Left" VerticalAlignment="Center"
                   Stretch="Uniform"/>

            <!-- Title + description -->
            <StackPanel Grid.Column="1" Margin="12,0,16,0" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText"
                           FontFamily="{DynamicResource Stamps.FontFamily}"
                           FontSize="{DynamicResource Stamps.FontSize.Body}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Stamps.Text.Primary}"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="DescText"
                           FontFamily="{DynamicResource Stamps.FontFamily}"
                           FontSize="{DynamicResource Stamps.FontSize.Caption}"
                           Foreground="{DynamicResource Stamps.Text.Secondary}"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Enable toggle -->
            <ui:ToggleSwitch x:Name="EnableToggle"
                             Grid.Column="2"
                             VerticalAlignment="Center"/>
        </Grid>
    </Border>
</UserControl>
