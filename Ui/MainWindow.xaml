<Window x:Class="Stamps.Ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Stamps"
        Width="960" Height="640"
        MinWidth="720" MinHeight="480"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="{DynamicResource Stamps.Background.Secondary}"
                BorderBrush="{DynamicResource Stamps.Border.Default}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- App name header -->
                <Border DockPanel.Dock="Top" Padding="24,20,24,16">
                    <TextBlock Text="Stamps"
                               FontFamily="{DynamicResource Stamps.FontFamily}"
                               FontSize="{DynamicResource Stamps.FontSize.Subtitle}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Stamps.Text.Primary}"/>
                </Border>

                <!-- Nav items -->
                <StackPanel Margin="8,0,8,8">
                    <RadioButton x:Name="NavTweaks"
                                 IsChecked="True"
                                 Style="{StaticResource SidebarNavItemStyle}"
                                 Checked="OnNavChecked">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="AppsAddIn24" Margin="0,0,10,0" FontSize="16"/>
                            <TextBlock Text="Tweaks" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavSettings"
                                 Style="{StaticResource SidebarNavItemStyle}"
                                 Checked="OnNavChecked">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Settings24" Margin="0,0,10,0" FontSize="16"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavAbout"
                                 Style="{StaticResource SidebarNavItemStyle}"
                                 Checked="OnNavChecked">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Info24" Margin="0,0,10,0" FontSize="16"/>
                            <TextBlock Text="About" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Right content area -->
        <Grid Grid.Column="1" Background="{DynamicResource Stamps.Background.Primary}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Page header -->
            <Border Grid.Row="0" Padding="28,20,28,12"
                    BorderBrush="{DynamicResource Stamps.Border.Default}"
                    BorderThickness="0,0,0,1">
                <TextBlock x:Name="HeaderTitle"
                           FontFamily="{DynamicResource Stamps.FontFamily}"
                           FontSize="{DynamicResource Stamps.FontSize.Title}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Stamps.Text.Primary}"/>
            </Border>

            <!-- Page content -->
            <ContentPresenter x:Name="ContentArea" Grid.Row="1"/>
        </Grid>
    </Grid>
</Window>
