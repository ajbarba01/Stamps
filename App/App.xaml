<Application x:Class="Stamps.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- WPF-UI base dictionaries (theme set at runtime by ThemeService) -->
                <ui:ThemesDictionary Theme="Dark"/>
                <ui:ControlsDictionary/>
                <!-- Stamps shared styles -->
                <ResourceDictionary Source="pack://application:,,,/Stamps;component/Ui/Theme/Styles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Stamps;component/Ui/Theme/Typography.xaml"/>
                <!-- Initial palette; ThemeService replaces this on startup -->
                <ResourceDictionary Source="pack://application:,,,/Stamps;component/Ui/Theme/Palettes/Dark.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
